# ── Shared JWT secret ─────────────────────────────────────────────────────────
JWT_SECRET=

# ── Auth service ──────────────────────────────────────────────────────────────
MFA_SECRET_KEY=

# ── Auth database ─────────────────────────────────────────────────────────────
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=

# ── Hub service database ──────────────────────────────────────────────────────
HUB_DB_USER=postgres
HUB_DB_PASSWORD=

# ── Bot credentials ───────────────────────────────────────────────────────────
BOT_SECRET=
BOT_PASSWORD=

# ── TURN server (coturn) ──────────────────────────────────────────────────────
# REQUIRED: set all three before deploying — these have no safe defaults
COTURN_REALM=
COTURN_USER=
COTURN_PASS=

# ── PeerJS ────────────────────────────────────────────────────────────────────
# Change to true for TLS on PeerJS
PEER_SECURE=false