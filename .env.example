# ── Shared JWT secret ─────────────────────────────────────────────────────────
JWT_SECRET=

# ── Auth service ──────────────────────────────────────────────────────────────
MFA_SECRET_KEY=

# ── Auth database ─────────────────────────────────────────────────────────────
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=

# ── Hub service database ──────────────────────────────────────────────────────
HUB_DB_USER=postgres
HUB_DB_PASSWORD=

# ── Bot credentials ───────────────────────────────────────────────────────────
BOT_SECRET=
BOT_PASSWORD=

# ── TURN server (coturn) ──────────────────────────────────────────────────────
COTURN_REALM=talk.local
COTURN_USER=talk
COTURN_PASS=talkpass

# ── PeerJS ────────────────────────────────────────────────────────────────────
# Change to true for TLS on PeerJS
PEER_SECURE=false