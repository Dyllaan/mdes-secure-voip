# Shared JWT secret
# Can be generated with: openssl rsa -pubout -in jwt-private.pem -out jwt-public.pem
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=
# Hub Service
# HS256 JWT secret for authenticating the MusicMan bot to the Hub. Should be a random 256-bit value, base64-encoded (32 bytes before encoding).
BOT_SECRET=
HUB_DB_PASSWORD=
# Hours before invite codes expire (default: 6)
INVITE_TTL_HOURS=6
# Limits
MAX_REQUEST_BODY_BYTES=1048576
MAX_HUB_NAME_LEN=25
MAX_CHANNEL_NAME_LEN=30
MAX_CIPHERTEXT_LEN=65536
MAX_IV_LEN=256
MAX_KEY_VERSION_LEN=64
MAX_PUBLIC_KEY_LEN=512
MAX_DEVICE_ID_LEN=128
MAX_BUNDLES_PER_REQUEST=500
# 1mb
MAX_REQUEST_BODY_BYTES=1048576


# Auth DB
AUTH_DB_PASSWORD=

# MusicMan bot
BOT_USERNAME=musicman
BOT_PASSWORD=

# TURN server
# 32-byte random value for TURN authentication, base64-encoded
# openssl rand -base64 32
TURN_SECRET=
TURN_HOST=10.10.10.10
TURN_PORT=3478
TURN_SECURE=false

COTURN_REALM=localhost
COTURN_USER=coturn_user
COTURN_PASS=
COTURN_EXTERNAL_IP=

# CORS (comma-separated origins, no trailing slash)
ALLOWED_ORIGINS=http://localhost:8080

# MusicMan media restrictions
# YouTube could be added, would require a cookie for a YT account
ALLOWED_VIDEO_ORIGINS=
ALLOWED_AUDIO_ORIGINS=soundcloud.com
YTDLP_MAX_FILESIZE_MB=50

# Auth demo mode
DEMO_MODE=false
# Users not restricted by demo mode
DEMO_ALLOWED_USERS=
ACCESS_TOKEN_EXP_SECONDS=120 # 2 minutes
REFRESH_TOKEN_EXP_SECONDS=2419200 # 28 days
MFA_TOKEN_EXP_SECONDS=300 # 5 minutes
DEMO_TOKEN_EXP_SECONDS=900 # 15 minutes
TRUSTED_DEVICE_VALIDITY_DAYS=30 # Number of days a trusted device remains valid
LOG_LEVEL=debug

REDIS_PASSWORD=
