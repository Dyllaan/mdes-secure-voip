# Copy this file to .env.local and fill in all values before starting services.
# .env.local is gitignored — never commit it.
# ALL existing secrets below must be rotated before deploying (treat as compromised).

# ── Auth Service ─────────────────────────────────────────────────────────────
SECRET_KEY=
TEMP_MFA_SECRET_KEY=

# ── Shared JWT secret (must match across gateway, realtime, hub, musicman) ───
JWT_SECRET=

# ── Hub Service ──────────────────────────────────────────────────────────────
BOT_SECRET=
HUB_DB_PASSWORD=
# Hours before invite codes expire (default: 24)
INVITE_TTL_HOURS=24

# ── Auth DB ──────────────────────────────────────────────────────────────────
AUTH_DB_PASSWORD=

# ── MusicMan bot ─────────────────────────────────────────────────────────────
BOT_PASSWORD=

# ── TURN server ──────────────────────────────────────────────────────────────
TURN_SECRET=
COTURN_REALM=
COTURN_USER=
COTURN_PASS=
COTURN_EXTERNAL_IP=

# ── CORS (comma-separated origins, no trailing slash) ────────────────────────
# Dev:  ALLOWED_ORIGINS=http://localhost:5173
# Prod: ALLOWED_ORIGINS=https://mdes.sh
ALLOWED_ORIGINS=

# ── MusicMan media restrictions ───────────────────────────────────────────────
ALLOWED_MEDIA_DOMAINS=youtube.com,youtu.be,soundcloud.com,spotify.com
YTDLP_MAX_FILESIZE_MB=50
