FROM golang:1.25-alpine AS builder

WORKDIR /app

COPY services/hub-service/go.mod services/hub-service/go.sum ./
RUN go mod download

COPY services/hub-service/ .

RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o hub-service .

FROM alpine:3.21

RUN apk --no-cache add ca-certificates tzdata

WORKDIR /app

COPY --from=builder /app/hub-service .

EXPOSE 8080

CMD ["./hub-service"]
