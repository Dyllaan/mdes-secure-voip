FROM golang:1.25-alpine AS builder

WORKDIR /app

COPY services/VoIPServer/go.mod services/VoIPServer/go.sum ./
RUN go mod download

COPY services/VoIPServer/ .

RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o voip-server .

FROM alpine:3.21

RUN apk --no-cache add ca-certificates tzdata

WORKDIR /app

COPY --from=builder /app/voip-server .

EXPOSE 8080

CMD ["./voip-server"]
